# Exclude ALL node_modules at any level – native modules must be compiled inside the container
**/node_modules
node_modules

# Logs
npm-debug.log*
*.log

# Environment secrets
.env
.env.*
!.env.example

# Generated runtime files (persisted via Docker volumes)
backend/uploads/*
!backend/uploads/.gitkeep
backend/outputs/*
!backend/outputs/.gitkeep
backend/data/*.db
backend/data/*.sqlite

# Test / dev artifacts
test_zip.zip
test_zip.js
backend/test-data.xlsx
backend/create-test-data.js
backend/debug_headers.log

# Version control & tooling
.git
.gitignore
.agent
*.bat
